; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ProjectFBDC"
run/main_scene="res://scenes/main/OutGame.tscn"
config/features=PackedStringArray("4.7", "Mobile")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

SoundManager="*res://scripts/managers/SoundManager.gd"
PlayLogger="*res://scripts/managers/PlayLogger.gd"
SceneTransition="*res://scripts/managers/SceneTransition.gd"
SettingsManager="*res://scripts/managers/SettingsManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/balance_tool/plugin.cfg", "res://addons/build_manager/plugin.cfg")

